# 환경변수 예시 - 실제 사용 시 .env.local 파일로 복사하여 사용

# 구글 서비스 계정 JSON (개행은 \n으로)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# 스프레드시트 ID (2개로 분리)
# AUTH_SHEET: 인증 정보 (email, password_hash, role, status, failed_count, locked_until)
AUTH_SHEET_ID=your-auth-spreadsheet-id-here

# DATA_SHEET: 데이터 (팀, 프로젝트, Help, Insight 등) + 개인정보(name, phone, org)
DATA_SHEET_ID=your-data-spreadsheet-id-here

# JWT 암호화 키 (64자 이상 랜덤 문자열 권장)
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-64-char-secret-key-here-change-this-in-production

# 앱 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
